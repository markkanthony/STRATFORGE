# StratForge environment variables
# Copy to .env and fill in values

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret

# Database — SQLite for dev (no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./stratforge.db
# PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/stratforge

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# Frontend URL (for CORS + Stripe redirect)
FRONTEND_URL=http://localhost:5173
